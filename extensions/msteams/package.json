{
  "name": "@littlebaby/msteams",
  "version": "2026.4.20",
  "description": "LittleBaby Microsoft Teams channel plugin",
  "type": "module",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/teams.api": "2.0.8",
    "@microsoft/teams.apps": "2.0.8",
    "@sinclair/typebox": "0.34.49",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1"
  },
  "devDependencies": {
    "@littlebaby/plugin-sdk": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "littlebaby": "workspace:*"
  },
  "peerDependencies": {
    "littlebaby": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "littlebaby": {
      "optional": true
    }
  },
  "littlebaby": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60
    },
    "install": {
      "npmSpec": "@littlebaby/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "littlebabyVersion": "2026.4.20"
    },
    "release": {
      "publishToLittleBabyHub": true,
      "publishToNpm": true
    }
  }
}
