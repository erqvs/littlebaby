{
  "name": "@littlebaby/feishu",
  "version": "2026.4.20",
  "description": "LittleBaby Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@sinclair/typebox": "0.34.49",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@littlebaby/plugin-sdk": "workspace:*",
    "littlebaby": "workspace:*"
  },
  "peerDependencies": {
    "littlebaby": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "littlebaby": {
      "optional": true
    }
  },
  "littlebaby": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (\u98de\u4e66)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "\u98de\u4e66/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@littlebaby/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "littlebabyVersion": "2026.4.20"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToLittleBabyHub": true,
      "publishToNpm": true
    }
  }
}
