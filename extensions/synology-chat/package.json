{
  "name": "@littlebaby/synology-chat",
  "version": "2026.4.20",
  "description": "Synology Chat channel plugin for LittleBaby",
  "type": "module",
  "devDependencies": {
    "@littlebaby/plugin-sdk": "workspace:*"
  },
  "littlebaby": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to LittleBaby with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@littlebaby/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
