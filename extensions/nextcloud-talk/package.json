{
  "name": "@littlebaby/nextcloud-talk",
  "version": "2026.4.20",
  "description": "LittleBaby Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "@littlebaby/plugin-sdk": "workspace:*",
    "littlebaby": "workspace:*"
  },
  "peerDependencies": {
    "littlebaby": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "littlebaby": {
      "optional": true
    }
  },
  "littlebaby": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@littlebaby/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "littlebabyVersion": "2026.4.20"
    },
    "release": {
      "publishToLittleBabyHub": true,
      "publishToNpm": true
    }
  }
}
