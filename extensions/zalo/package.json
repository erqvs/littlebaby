{
  "name": "@littlebaby/zalo",
  "version": "2026.4.20",
  "description": "LittleBaby Zalo channel plugin",
  "type": "module",
  "dependencies": {
    "undici": "8.1.0"
  },
  "devDependencies": {
    "@littlebaby/plugin-sdk": "workspace:*",
    "littlebaby": "workspace:*"
  },
  "peerDependencies": {
    "littlebaby": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "littlebaby": {
      "optional": true
    }
  },
  "littlebaby": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@littlebaby/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "littlebabyVersion": "2026.4.20"
    },
    "release": {
      "publishToLittleBabyHub": true,
      "publishToNpm": true
    }
  }
}
