// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

LITTLEBABY_CODE_SIGN_STYLE = Manual
LITTLEBABY_DEVELOPMENT_TEAM = Y5PE65HELJ

LITTLEBABY_APP_BUNDLE_ID = ai.littlebaby.client
LITTLEBABY_SHARE_BUNDLE_ID = ai.littlebaby.client.share
LITTLEBABY_WATCH_APP_BUNDLE_ID = ai.littlebaby.client.watchkitapp
LITTLEBABY_WATCH_EXTENSION_BUNDLE_ID = ai.littlebaby.client.watchkitapp.extension
LITTLEBABY_ACTIVITY_WIDGET_BUNDLE_ID = ai.littlebaby.client.activitywidget

LITTLEBABY_APP_PROFILE = ai.littlebaby.client Development
LITTLEBABY_SHARE_PROFILE = ai.littlebaby.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
